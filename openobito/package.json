{
  "name": "openagent",
  "version": "0.1.0",
  "description": "Your local AI agent. Safe, smart, always offline.",
  "type": "module",
  "license": "EPL-2.0",
  "author": "OpenAgent Contributors",
  "homepage": "https://github.com/openagent-dev/openagent",
  "repository": {
    "type": "git",
    "url": "https://github.com/openagent-dev/openagent.git"
  },
  "keywords": ["ai", "agent", "cli", "ollama", "local", "offline", "llm"],
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "scripts": ["dist/**/*.js"],
    "assets": ["skills/**/*", ".agents/**/*", "LICENSE"],
    "targets": ["node18-linux-x64", "node18-macos-x64", "node18-win-x64"],
    "outputPath": "dist"
  },
  "bin": {
    "openobito": "./bin/openobito.js",
    "openagent": "./bin/openagent.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin/",
    "dist/",
    "public/",
    "scripts/postinstall.js",
    "skills/",
    ".agents/",
    "docs/",
    "AGENTS.md",
    "AGENT.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsx watch src/cli/index.ts",
    "postinstall": "node scripts/postinstall.js",
    "start": "node bin/openagent.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "bench": "node scripts/bench.js",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
