{
  "name": "openagent-desktop",
  "version": "0.1.0",
  "description": "OpenAgent Desktop — Electron wrapper for the CLI AI agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.openagent.desktop",
    "productName": "OpenAgent",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "../bin/openagent.js",
      "../dist/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
